# Bastillefile for quickheadlines (Svelte 5 Frontend)

# --- Arguments ---
ARG MODE=prod
ARG TAG=
ARG REPO_URL=https://github.com/kritoke/quickheadlines.git
ARG CLEAR_CACHE=false

# 0. Initial Cleanup & Service Stop
CMD service quickheadlines stop 2>/dev/null || true
CMD sleep 2
CMD pkill -9 -u qh 2>/dev/null || true
CMD rm -f /var/run/quickheadlines/quickheadlines.pid /tmp/skip_download 2>/dev/null || true

# 1. System Dependencies
PKG ca_root_nss crystal shards git openssl gmake curl sqlite3 sudo libevent libyaml node npm
CMD ln -sf /usr/local/share/certs/ca-root-nss.crt /etc/ssl/cert.pem 2>/dev/null || true

# 2. User & Directory Setup
CMD pw useradd qh -d /usr/local/share/quickheadlines -s /usr/sbin/nologin 2>/dev/null || true
CMD mkdir -p /usr/local/share/quickheadlines /var/cache/quickheadlines /home/qh /var/run/quickheadlines /var/log/quickheadlines /tmp/qh
CMD chown -R qh:qh /usr/local/share/quickheadlines /var/cache/quickheadlines /home/qh /var/run/quickheadlines /var/log/quickheadlines /tmp/qh

# 3. Persistence Cache
FSTAB /usr/local/bastille/cache/crystal/quickheadlines /home/qh/.cache nullfs rw 0 0

# 4. Binary Guard (The "No-Arg" Fix)
CMD [ "${MODE}" != "dev" ] && [ -f /usr/local/share/quickheadlines/quickheadlines ] && touch /tmp/skip_download

# 5. Cache Clear (Optional)
CMD [ "${CLEAR_CACHE}" = "true" ] && rm -rf /home/qh/.cache/shards /var/cache/quickheadlines/* /tmp/qh

# 6. Clone Source (Into /tmp/qh)
CMD rm -rf /tmp/qh && git clone ${REPO_URL} /tmp/qh && chown -R qh:qh /tmp/qh

# 7a. DEV MODE: Build (Only runs if MODE=dev)
CMD if [ "${MODE}" = "dev" ]; then
    echo "🛠️ MODE: dev - Compiling from source..."
    npm install -g pnpm
    # Fix pnpm esbuild build issue on FreeBSD
    echo "onlyBuiltDependencies=[\"esbuild\"]" >> /tmp/qh/frontend/.npmrc
    cd /tmp/qh/frontend && pnpm install
    echo "Building Svelte frontend..."
    cd /tmp/qh/frontend && pnpm run build
    # Copy logo.svg to dist
    cp /tmp/qh/frontend/static/logo.svg /tmp/qh/frontend/dist/ 2>/dev/null || true
    # Verify frontend assets
    if [ ! -f /tmp/qh/frontend/dist/index.html ]; then
        echo "❌ ERROR: frontend/dist/index.html not found!"
        exit 1
    fi
    if [ ! -d /tmp/qh/frontend/dist/_app ]; then
        echo "❌ ERROR: frontend/dist/_app not found!"
        exit 1
    fi
    echo "✓ Frontend assets verified"
    ls -la /tmp/qh/frontend/dist/
    # Build Crystal binary
    cd /tmp/qh && shards install && touch src/web/assets.cr
    crystal build --release -Os -Dpreview_lto src/quickheadlines.cr -o /tmp/qh/quickheadlines
    touch /tmp/skip_download
fi

# 7b. PROD MODE: Dynamic Download
CMD if [ ! -f /tmp/skip_download ]; then
    echo "📦 MODE: prod - Downloading latest release..."
    LATEST=$(git ls-remote --sort=v:refname --tags ${REPO_URL} | tail -1 | cut -d/ -f3)
    V="${TAG:-$LATEST}"
    echo "📥 Downloading version: $V"
    curl -fSL "https://github.com/kritoke/quickheadlines/releases/download/$V/quickheadlines-$V-freebsd-x64" -o /tmp/qh/quickheadlines
fi

# 8. THE ATOMIC SWAP
CMD if [ -f /tmp/qh/quickheadlines ]; then
    [ -f /usr/local/share/quickheadlines/quickheadlines ] && rm -f /usr/local/share/quickheadlines/quickheadlines.old
    mv /tmp/qh/quickheadlines /usr/local/share/quickheadlines/quickheadlines
    chmod +x /usr/local/share/quickheadlines/quickheadlines
fi

# 9. Config & Service Setup
CMD [ ! -f /usr/local/share/quickheadlines/feeds.yml ] && curl -fSL https://raw.githubusercontent.com/kritoke/quickheadlines/main/feeds.yml -o /usr/local/share/quickheadlines/feeds.yml
CMD [ ! -f /usr/local/etc/rc.d/quickheadlines ] && curl -fSL https://raw.githubusercontent.com/kritoke/quickheadlines/main/misc/quickheadlines -o /usr/local/etc/rc.d/quickheadlines && chmod +x /usr/local/etc/rc.d/quickheadlines

# 10. Launch
SYSRC quickheadlines_enable="YES"
CMD chown -R qh:qh /usr/local/share/quickheadlines /var/run/quickheadlines
CMD rm -f /tmp/skip_download
CMD sleep 2
CMD service quickheadlines onestart