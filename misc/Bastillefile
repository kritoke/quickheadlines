# Bastillefile for quickheadlines (Svelte 5 Frontend)

# --- Arguments (Restored to your original working pattern) ---
ARG MODE=prod
ARG TAG=
ARG REPO_URL=https://github.com/kritoke/quickheadlines.git
ARG CLEAR_CACHE=false

# 1. System Dependencies
PKG ca_root_nss crystal shards git openssl gmake curl sqlite3 sudo libevent libyaml node npm
CMD ln -sf /usr/local/share/certs/ca-root-nss.crt /etc/ssl/cert.pem 2>/dev/null || true

# 2. User & Directory Setup
# Added /var/run/quickheadlines here to ensure the service has its PID home
CMD pw useradd qh -d /usr/local/share/quickheadlines -s /usr/sbin/nologin 2>/dev/null || true
CMD mkdir -p /usr/local/share/quickheadlines /var/cache/quickheadlines /home/qh /var/run/quickheadlines /var/log/quickheadlines
CMD chown -R qh:qh /usr/local/share/quickheadlines /var/cache/quickheadlines /home/qh /var/run/quickheadlines /var/log/quickheadlines

# 3. Persistence Cache
FSTAB /usr/local/bastille/cache/crystal/quickheadlines /home/qh/.cache nullfs rw 0 0

# 4. Clone and Prepare
# We explicitly clean /tmp/qh first to avoid "already exists" errors
CMD service quickheadlines stop 2>/dev/null || true
CMD pkill -u qh 2>/dev/null || true
CMD rm -f /var/run/quickheadlines/quickheadlines.pid 2>/dev/null || true
CMD rm -rf /tmp/qh
CMD git clone ${REPO_URL} /tmp/qh
CMD chown -R qh:qh /tmp/qh

# 5. Clear cache if requested
CMD sh -c "if [ '${CLEAR_CACHE}' = 'true' ]; then rm -rf /home/qh/.cache/shards; fi"

# 6. Get binary (Using the interpolation style that worked for you)
# 6a. DEV MODE: Install Shards
CMD sh -c "if [ '${MODE}' = 'dev' ]; then cd /tmp/qh && sudo -u qh sh -c 'export HOME=/home/qh && export PATH=/usr/local/bin:/usr/bin:/bin && cd /tmp/qh && shards install'; fi"

# 6b. DEV MODE: Build Frontend (Atomic logic)
CMD sh -c "if [ '${MODE}' = 'dev' ] && [ -d '/tmp/qh/frontend' ]; then npm install -g pnpm && cd /tmp/qh/frontend && pnpm install && npx svelte-kit sync && pnpm run build; fi"

# 6c. DEV MODE: Compile Binary
CMD sh -c "if [ '${MODE}' = 'dev' ]; then mkdir -p /tmp/qh/src/web && touch /tmp/qh/src/web/assets.cr && sudo -u qh sh -c 'export HOME=/home/qh && export PATH=/usr/local/bin:/usr/bin:/bin && cd /tmp/qh && crystal build --release -Os -Dpreview_lto src/quickheadlines.cr -o /usr/local/share/quickheadlines/quickheadlines'; fi"

# 6d. PROD MODE: Download (Only runs if NOT dev)
CMD sh -c "if [ '${MODE}' != 'dev' ]; then LATEST_TAG=\$(git ls-remote --sort=v:refname --tags ${REPO_URL} | tail -1 | cut -d/ -f3); VERSION='${TAG:-\$LATEST_TAG}'; curl -fSL \"https://github.com/kritoke/quickheadlines/releases/download/\${VERSION}/quickheadlines-\${VERSION}-freebsd-x64\" -o /usr/local/share/quickheadlines/quickheadlines; fi"

# 7. Config & Service Setup
CMD chmod +x /usr/local/share/quickheadlines/quickheadlines
CMD sh -c 'TARGET="/usr/local/share/quickheadlines/feeds.yml"; if [ ! -f "$TARGET" ]; then if [ -f "/tmp/qh/feeds.yml" ]; then cp /tmp/qh/feeds.yml "$TARGET"; else curl -fSL "https://raw.githubusercontent.com/kritoke/quickheadlines/main/feeds.yml" -o "$TARGET"; fi; fi'
CMD sh -c 'RCSCRIPT="/usr/local/etc/rc.d/quickheadlines"; if [ ! -f "$RCSCRIPT" ]; then if [ -f "/tmp/qh/misc/quickheadlines" ]; then cp /tmp/qh/misc/quickheadlines "$RCSCRIPT"; else curl -fSL "https://raw.githubusercontent.com/kritoke/quickheadlines/main/misc/quickheadlines" -o "$RCSCRIPT"; fi; fi && chmod +x "$RCSCRIPT"'

# 9. Start
SYSRC quickheadlines_enable="YES"
CMD chown -R qh:qh /usr/local/share/quickheadlines /var/run/quickheadlines
CMD sleep 2
CMD service quickheadlines onestart